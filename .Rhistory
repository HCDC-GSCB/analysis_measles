## ITS
df_ep1 <- df_ep1 %>%
mutate(
intervention1 = ifelse(dates >= end_intervention_dates, 1, 0),
post_intervention1_time = ifelse(dates >= end_intervention_dates, time - min(time[dates >= end_intervention_dates]) + 1, 0),
)
library(nlme)
model_a <- gls(rt ~ time + intervention1 + post_intervention1_time,
data = df_ep1, method = "ML")
library(AICcmodavg)
df_ep1 <- df_ep1 %>% mutate(
model_a_predictions = predictSE.gls (model_a, df_ep1, se.fit=T)$fit,
model_a_se = predictSE.gls (model_a, df_ep1, se.fit=T)$se
)
ggplot(df_ep1 ,aes(time, rt))+
geom_ribbon(aes(ymin = model_a_predictions - (1.96*model_a_se), ymax = model_a_predictions + (1.96*model_a_se)), fill = "lightgreen")+
geom_line(aes(time,model_a_predictions),color="black",lty=1)+
geom_point(alpha=0.3)
df_ep11 <- filter(df_ep1, time < knots)
model_c = gls(rt ~ time, data = df_ep11, method="ML")
df_ep1 <- df_ep1 %>% mutate(
model_c_predictions = predictSE.gls (model_c, newdata = df_ep1, se.fit=T)$fit,
model_c_se = predictSE.gls (model_c, df_ep1, se.fit=T)$se
)
p_its_overlap <- ggplot(df_ep1, aes(x = time)) +
# --- LỚP 1: KHÔNG CAN THIỆP ---
geom_ribbon(aes(ymin = model_c_predictions - (1.96*model_c_se),
ymax = model_c_predictions + (1.96*model_c_se)),
fill = "pink", alpha = 0.5) +
geom_line(aes(y = model_c_predictions,
color = "ITS model without intervention",
linetype = "ITS model without intervention"), size = 1) +
# --- LỚP 2: CÓ CAN THIỆP ---
geom_ribbon(aes(ymin = model_a_predictions - (1.96*model_a_se),
ymax = model_a_predictions + (1.96*model_a_se)),
fill = "lightgreen", alpha = 0.5) +
geom_line(aes(y = model_a_predictions,
color = "ITS model with intervention",
linetype = "ITS model with intervention"), size = 1) +
# --- LỚP 3: ĐIỂM DỮ LIỆU ---
geom_point(aes(y = rt, color = "Rt"), alpha = 0.5) +
# --- MÀU SẮC & KIỂU ĐƯỜNG ---
scale_color_manual(name = NULL,
values = c("ITS model with intervention" = "black",
"ITS model without intervention" = "red",
"Rt" = "gray30")) +
scale_linetype_manual(name = NULL,
values = c("ITS model with intervention" = 1,
"ITS model without intervention" = 2,
"Rt" = 0)) +
# --- QUAN TRỌNG: GOM CHÚ THÍCH ---
guides(
# 1. Tắt legend riêng của linetype (để không bị thừa)
linetype = "none",
# 2. Chỉnh legend của color để hiển thị đúng icon (gộp cả shape và linetype vào đây)
color = guide_legend(
override.aes = list(
# Thứ tự alphabet: 1. Có... -> 2. Không... -> 3. Rt
linetype = c(1, 2, 0),        # Solid, Dashed, Blank
shape = c(NA, NA, 16),        # Không point, Không point, Tròn
size = c(1, 1, 3)             # Size icon
)
)
) +
scale_y_continuous(name = expression(R[t]),
breaks = seq(-0.5,2.5,0.5)) +
scale_x_continuous(name = "Times (Days)") +
theme_classic() +
theme(
text = element_text(size = 16, color = "black"),
axis.text = element_text(size = 16, color = "black"),
axis.title = element_text(size = 16, color = "black"),
legend.text = element_text(size = 16, color = "black"),
legend.position = "top",
legend.background = element_rect(fill = "transparent")
)
ggsave("its_oub1.jpeg", plot = p_its_overlap, dpi = 500,
height = 6, width = 12, bg = "white")
### Relative differences for ITS models
df_compare <- df_ep1 %>%
select(time, dates, rt, model_a_predictions, model_c_predictions) %>%
filter(time >= min(df_ep1$time[df_ep1$intervention1 == 1])) %>% # Chỉ lấy giai đoạn sau can thiệp
mutate(
absolute_diff = model_a_predictions - model_c_predictions,
relative_diff_percent = (absolute_diff / model_c_predictions) * 100
)
mean_reduction <- mean(df_compare$relative_diff_percent)
print(paste("Trung bình can thiệp làm thay đổi Rt:", round(mean_reduction, 2), "%"))
