)))
ggsave("piecewise_oub1.jpeg", piecewise, dpi = 500,
height = 7, width = 11, bg = "white")
library(marginaleffects)
a <- knots/2
b <- (max(df_ep1$time) + knots)/2
representative <- c(a,b)
slope_results <- slopes(
m,
newdata = datagrid(time = representative),
variables = "time"
)
